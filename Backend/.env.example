NODE_ENV=development
PORT=5001
# App reads MONGO_URI (Atlas connection string)
MONGO_URI=mongodb://127.0.0.1:27017/rideeasy
JWT_SECRET=change-me-min-32-chars-random

# Atlas collections used by this app (same DB):
# users = passengers/customers | drivers = captains | rides = bookings
# admins | pricings | blacklisttokens (logout JWT blocklist, TTL ~7d)
# Drop unused empty collections (bookings, customers, captions, etc.) if you added them by mistake — they are NOT used.

# Production: comma-separated frontend origins (required if NODE_ENV=production unless CORS_ALLOW_ALL=true)
# Example Render: CORS_ORIGINS=https://rideeasy-web.onrender.com
# CORS_ORIGINS=
# CLIENT_ORIGINS=   (alias for CORS_ORIGINS)

# Log Origin + ACAO on each request (dev only)
# CORS_DEBUG=true

RATE_LIMIT_MAX=400
COMMISSION_PERCENT=15

# Optional: Sentry error monitoring
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0

# Optional: enforce HTTPS redirects (behind proxy/load balancer)
# FORCE_HTTPS=false
# When in production and CORS_ORIGINS is not set, you can allow all with:
# CORS_ALLOW_ALL=true

# Optional server-side maps
# GOOGLE_MAPS_API_KEY=

# Razorpay (live)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
