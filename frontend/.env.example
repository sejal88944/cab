# Vite — copy to .env or .env.production (never commit real .env)

# तुमचा LIVE Node + Socket.IO server (HTTPS, no trailing slash)
# उदा: https://api.majhacompany.com
VITE_BASE_URL=http://192.168.1.5:5001

# Browser: Maps + Places (restrict key by HTTP referrer in Google Cloud)
VITE_GOOGLE_MAPS_API_KEY=

# UPI payment config
# Handle is used for actual payment intent
VITE_UPI_HANDLE=merchant@upi
# Name only for UI display (you can keep this as RideEasy)
VITE_UPI_PAYEE_NAME=RideEasy

# Optional: Sentry browser DSN (npm i @sentry/react first)
# VITE_SENTRY_DSN=
# Optional: Enable tracing/APM sampling rate (0 disables tracing)
# VITE_SENTRY_TRACES_SAMPLE_RATE=0
