# Vite env files:
#   .env              → local dev (npm run dev) — copy from this file; usually gitignored
#   .env.production   → production build (npm run build) — public API URL only
# Render dashboard: set VITE_* for cloud builds too.

# Local dev — no trailing slash
VITE_BASE_URL=http://localhost:5001

# Production example (use .env.production or Render env):
# VITE_BASE_URL=https://your-backend-xxxx.onrender.com

# Backend on serverless cannot hold Socket.IO — optional:
# VITE_DISABLE_SOCKET=true

# Browser: Maps (restrict key by HTTP referrer in Google Cloud)
VITE_GOOGLE_MAPS_API_KEY=

# UPI payment config
VITE_UPI_HANDLE=merchant@upi
VITE_UPI_PAYEE_NAME=RideEasy

# Optional: Sentry
# VITE_SENTRY_DSN=
# VITE_SENTRY_TRACES_SAMPLE_RATE=0
